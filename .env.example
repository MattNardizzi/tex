# Tex environment template — copy to .env and fill in. NEVER commit a real .env.
# (.env / .env.* are gitignored; this .example is the one tracked exception.)
#
# Grouped by what breaks if you omit it. The web image is a single-process,
# single-worker PDP; durable shared state lives in Postgres (DATABASE_URL) and
# the evidence hash-chain lives on a persistent volume. See deploy/DURABILITY.md.

# ─────────────────────────────────────────────────────────────────────────────
# DURABILITY — set DATABASE_URL or you run pure in-memory (state lost on restart)
# ─────────────────────────────────────────────────────────────────────────────
# When set, every durable store writes through to Postgres synchronously
# (src/tex/db/connection.py, src/tex/memory/_db.py); schema is bootstrapped
# idempotently on boot. When UNSET, all stores fall back to in-memory and a
# restart erases decisions, policies, the evidence mirror, and registries.
DATABASE_URL=postgres://tex:CHANGE_ME@localhost:5432/tex

# The authoritative evidence record is a hash-chained JSONL file the recorder
# continues from on boot. The served app writes it CWD-relative at
# var/tex/evidence/evidence.jsonl; in the Docker image WORKDIR=/app, so it lands
# at /app/var/tex/evidence/evidence.jsonl — mount a volume there to survive
# restarts. NOTE: the module-level app does NOT currently read TEX_EVIDENCE_PATH
# (tracked follow-up); this var is honored only by callers that pass it through.
# TEX_EVIDENCE_PATH=/app/var/tex/evidence/evidence.jsonl

# ─────────────────────────────────────────────────────────────────────────────
# PRODUCTION FAIL-CLOSED — required when TEX_APP_ENV is production-like
# (anything NOT in: dev, development, test, testing, local). The app REFUSES to
# boot, or fails requests closed (401), if these are missing in prod.
# ─────────────────────────────────────────────────────────────────────────────
TEX_APP_ENV=production

# Required in prod: HMAC key for evidence-bundle manifest signing. Must be a
# real, high-entropy value (>= 32 bytes from a CSPRNG); the in-repo sentinel
# ("dev-only-change-me") is rejected at startup outside non-prod envs.
#   generate:  python -c "import secrets; print(secrets.token_urlsafe(48))"
TEX_EVIDENCE_SUMMARY_SECRET=CHANGE_ME_32_BYTES_MIN

# Required in prod (or whenever TEX_REQUIRE_AUTH=1): API keys, or every
# authenticated route fails closed with 401. Comma-separated entries of
#   <key>[:<tenant>[:<scopes>]]   scopes are '+'-separated; omit scopes for the
# default read+write set. Example:
#   TEX_API_KEYS="key_abc:tenant_acme:decision:write+evidence:read,key_admin:internal:admin:read+admin:write+admin:cross_tenant"
TEX_API_KEYS=

# TEE attestation mode. Defaults to 'production'; 'test' is forbidden in prod
# (would emit non-attested evidence). Leave unset unless you know you need it.
# TEX_TEE_ATTESTATION_MODE=production

# ─────────────────────────────────────────────────────────────────────────────
# AUTH / CORS (optional hardening)
# ─────────────────────────────────────────────────────────────────────────────
# Force auth even in a non-production TEX_APP_ENV.
# TEX_REQUIRE_AUTH=1
# Comma-separated allowed origins (never '*' with credentials). Unset = locked.
# TEX_CORS_ALLOW_ORIGINS=https://app.example.com

# ─────────────────────────────────────────────────────────────────────────────
# SERVER
# ─────────────────────────────────────────────────────────────────────────────
# TEX_HOST=0.0.0.0
# TEX_PORT=8080

# ─────────────────────────────────────────────────────────────────────────────
# OBSERVABILITY — /metrics is always on (pure-Python OpenMetrics, zero deps).
# OTLP push is OPTIONAL and lights up only if opentelemetry-sdk is installed AND
# an endpoint is set (otherwise it is a silent no-op). See observability/metrics_export.py.
# ─────────────────────────────────────────────────────────────────────────────
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
# OTEL_SERVICE_NAME=tex
# TEX_METRICS_OTLP_INTERVAL_SECONDS=30

# ─────────────────────────────────────────────────────────────────────────────
# DISCOVERY (optional) — standing-watch scan loop
# ─────────────────────────────────────────────────────────────────────────────
# TEX_DISCOVERY_SCAN_INTERVAL_SECONDS=3600
# TEX_DISCOVERY_SCAN_TENANTS=tenant_acme,tenant_globex

# ─────────────────────────────────────────────────────────────────────────────
# SEMANTIC PROVIDER (optional) — if 'openai', OPENAI_API_KEY becomes required
# ─────────────────────────────────────────────────────────────────────────────
# TEX_SEMANTIC_PROVIDER=openai
# OPENAI_API_KEY=
