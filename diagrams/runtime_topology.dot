"uvicorn" -> "alerts_py356";
"scheduler_py154" [label="threading.Thread\nscheduler.py:154\nBackgroundScanScheduler thread\nscans tenants on interval\ntouches discovery ledger" fillcolor="#f3efe9" fontcolor="black"];
"lifespan" -> "scheduler_py154";
"__main___py64" [label="threading.Thread\n__main__.py:64\noperator CLI worker thread (separate entrypoint)" fillcolor="#b0852a" fontcolor="white"];
"uvicorn" -> "__main___py64";
"feed_py233" [label="threading.Thread\nfeed.py:233\nContinuousProvenanceFeed thread\nheld-decision sink" fillcolor="#f3efe9" fontcolor="black"];
