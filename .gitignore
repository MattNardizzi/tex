# Environment / secrets
.env
.env.*
!.env.example
*.key
*.pem
# EXCEPTION: the pinned Free TSA *public* root CA is intentionally tracked — a
# relying party needs it to verify anchor receipts offline, with no network.
# It is public, not a secret; the *.pem rule above is for PRIVATE key material.
!anchors/tsa/freetsa_cacert.pem
secrets/
credentials.json

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/

# Node
node_modules/
.next/
dist/
build/

# Build artifacts of the marketing site (tex-frontend/): near-duplicate zip
# exports that bloat the public repo. Kept locally, untracked (see CURATION.md).
tex-frontend*.zip

# OS / editor
.DS_Store
.vscode/
.idea/
*.swp

# Logs
*.log
logs/
tex_build_master_prompt.md

# Runtime state — written by the app at boot; never belongs in version control.
# var/tex/evidence/  = the hash-chained evidence JSONL (EvidenceRecorder continues
#                      it from the file on boot; in prod it rides a persistent volume)
# var/tex/keys/      = the evidence-seal signing key, incl. PRIVATE key material
#                      (regenerated on a fresh deploy; must never be committed)
var/
# Same runtime state when the app runs with the package root (src/) as CWD. The
# bare `var/` above is root-anchored and does NOT match `src/var/`, so a second
# copy of the PRIVATE seal key + evidence chain slipped past #12.
src/var/
data/

# Forge challenge PRIVATE keys. The forge/ dir is otherwise INTENTIONALLY
# tracked (public bundles + pins below), but the private seal keys that sign the
# canonical bundles must NEVER be committed — their secrecy is exactly what makes
# the forge dare real. var/ above is root-anchored and does NOT cover forge/, so
# these explicit rules are mandatory.
forge/_private_keys/
forge/**/*private*
# INTENTIONALLY COMMITTED public material under forge/ (do NOT ignore these):
#   forge/canonical_bundle.pq.jsonl      (composite ML-DSA-65 + Ed25519 bundle)
#   forge/canonical_bundle.ecdsa.jsonl   (ECDSA-P256 verify-anywhere bundle)
#   forge/PUBKEY_STATEMENT.json          (out-of-band pin, composite)
#   forge/PUBKEY_STATEMENT.ecdsa.json    (out-of-band pin, classical)
#   forge/README.md                      (operator doc)
