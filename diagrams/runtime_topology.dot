digraph rt {
rankdir=LR; bgcolor="white";
node [shape=box style="rounded,filled" fontname="Helvetica" fontsize=10];
label="Tex — runtime/concurrency topology (code-derived spawn sites)"; labelloc=b; fontsize=10;
"uvicorn" [label="uvicorn tex.main:app\n(ASGI worker)" fillcolor="#14110d" fontcolor="white"];
"lifespan" [label="FastAPI lifespan hook\nmain.py:1257\nstart/stop scheduler" fillcolor="#f3efe9"];
"uvicorn" -> "lifespan";
